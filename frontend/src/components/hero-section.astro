---
import ScannerForm from "./scanner-form";
import { heroLines } from "@/data/hero-lines";
---

<section
  class="mx-auto flex min-h-[50dvh] max-w-7xl justify-between px-4 xs:px-6 md:px-8"
>
  <div class="mx-auto flex flex-col justify-center md:mx-0">
    <div
      class="mb-12 text-center text-7xl tracking-tighter xs:text-8xl md:text-left"
    >
      <span class="block">Analyze</span>
      <span class="block">
        {" "}
        your{" "}
        <span
          id="highlight-text"
          class="mt-8 inline-block bg-linear-to-br from-orange-400 to-orange-600 px-6 py-0 leading-none font-bold"
        >
          slop
        </span>
      </span>
    </div>
    <ScannerForm client:load />
    <p class="mt-6 text-stone-800">*please don't abuse it, i'm broke</p>
    <p class="text-stone-900">
      **disclaimer: your website is not slop, it's great!
    </p>
  </div>
  <div
    class="hidden h-124 flex-col overflow-hidden border-accent mask-t-from-80% py-2 md:flex"
  >
    <div class="flex min-h-full shrink-0 animate-marquee-vertical flex-col">
      {/* vertical scrolling animation :P */}
      {
        heroLines.map((line: string, index: number) => (
          <h2 id={`first-${index}`} class="py-1">
            {line}
          </h2>
        ))
      }
    </div>

    <div class="flex min-h-full shrink-0 animate-marquee-vertical flex-col">
      {
        heroLines.map((line: string, index: number) => (
          <h2 id={`second-${index}`} class="py-1">
            {line}
          </h2>
        ))
      }
    </div>
  </div>
</section>
